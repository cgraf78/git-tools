#!/usr/bin/env bash
# Audit local branches against the default branch and optionally drop merged ones.

set -euo pipefail

# shellcheck disable=SC2034 # consumed by lib/git-tools-pr.sh after dynamic source
gt_command="git branch-audit"

_script_path="${BASH_SOURCE[0]}"
while [[ -L "$_script_path" ]]; do
  _script_dir=$(cd -P -- "$(dirname -- "$_script_path")" && pwd)
  _link=$(readlink "$_script_path")
  case "$_link" in
    /*) _script_path="$_link" ;;
    *) _script_path="$_script_dir/$_link" ;;
  esac
done
_root=$(cd -P -- "$(dirname -- "$_script_path")/.." && pwd)
# shellcheck disable=SC1091
. "$_root/lib/git-tools-pr.sh"
# shellcheck disable=SC1091
. "$_root/lib/git-tools-base.sh"

_usage() {
  cat <<'EOF'
Usage: git branch-audit [options]

List local branches with their state relative to the default branch: last commit
age, ahead/behind counts, whether they are merged into the default branch, and
the open PR number when GitHub data is available. The default branch itself is
the reference point and is omitted from the listing.

Options:
      --porcelain        Print stable tab-separated branch records.
      --drop-merged      Delete branches already merged into the default branch.
      --yes              Confirm --drop-merged.
  -b, --base <branch>    Use this branch as the default instead of inferring one.
  -n, --dry-run          Print drop actions without changing anything.
  -h, --help             Show this help.

Exit status:
  0  Audit or cleanup completed.
  1  Branch deletion failed.
  2  Usage or local environment error.
EOF
}

_porcelain=0
_drop_merged=0
_yes=0
_dry_run=0
_base=""

while (($#)); do
  case "$1" in
    --porcelain)
      _porcelain=1
      shift
      ;;
    --drop-merged)
      _drop_merged=1
      shift
      ;;
    --yes)
      _yes=1
      shift
      ;;
    -b | --base)
      shift
      (($#)) || gt_usage_error "--base requires a value"
      _base="$1"
      shift
      ;;
    --base=*)
      _base="${1#--base=}"
      [[ -n "$_base" ]] || gt_usage_error "--base requires a value"
      shift
      ;;
    -n | --dry-run)
      _dry_run=1
      shift
      ;;
    -h | --help)
      _usage
      exit 0
      ;;
    -*)
      gt_usage_error "unexpected option: $1"
      ;;
    *)
      gt_usage_error "unexpected argument: $1"
      ;;
  esac
done

# Resolve the default branch to a concrete ref so ahead/behind and merge checks
# work even when only a remote-tracking copy exists locally.
_resolve_default() {
  if [[ -n "$_base" ]]; then
    _default="$_base"
  else
    # origin is the conventional default remote; naming it also keeps the
    # shared helper's optional argument explicit for shellcheck (SC2119).
    _default=$(gt_default_branch origin) ||
      gt_usage_error "could not determine default branch; pass --base <branch>"
  fi

  if git show-ref --verify --quiet "refs/heads/$_default"; then
    _default_ref="$_default"
  elif git show-ref --verify --quiet "refs/remotes/origin/$_default"; then
    _default_ref="origin/$_default"
  else
    gt_usage_error "default branch ref not found: $_default"
  fi
}

_branch_records() {
  git for-each-ref \
    --format='%(refname:short)%09%(committerdate:unix)%09%(committerdate:relative)%09%(upstream:track)' \
    refs/heads
}

_list() {
  local name cdate crel track behind ahead merged gone pr

  while IFS=$'\t' read -r name cdate crel track; do
    [[ -n "$name" ]] || continue
    [[ "$name" != "$_default" ]] || continue

    read -r behind ahead < <(git rev-list --left-right --count "$_default_ref...$name" 2>/dev/null || printf '0 0\n')
    merged=false
    # Squash/rebase merges are recognized too, so the merged flag is not stuck
    # on "false" for branches landed via a squash PR.
    gt_branch_merged "$name" "$_default_ref" && merged=true
    gone=false
    [[ "$track" == "[gone]" ]] && gone=true
    pr=$(gt_pr_number_for_branch "$name" || true)

    if [[ "$_porcelain" == 1 ]]; then
      printf 'branch\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
        "$name" "$merged" "$ahead" "$behind" "$pr" "$cdate" "$gone"
    else
      printf '%s merged=%s ahead=%s behind=%s gone=%s' "$name" "$merged" "$ahead" "$behind" "$gone"
      [[ -z "$pr" ]] || printf ' pr=#%s' "$pr"
      printf ' (%s)\n' "$crel"
    fi
  done < <(_branch_records)
}

_drop() {
  local name path current dropped=0 skipped=0

  if [[ "$_dry_run" == 0 && "$_yes" == 0 ]]; then
    gt_usage_error "--drop-merged requires --yes or --dry-run"
  fi

  current=$(git symbolic-ref -q --short HEAD || true)

  while IFS= read -r name; do
    [[ -n "$name" ]] || continue
    [[ "$name" != "$_default" ]] || continue
    gt_branch_merged "$name" "$_default_ref" || continue

    if [[ "$name" == "$current" ]]; then
      gt_say "skipping $name; current branch"
      skipped=$((skipped + 1))
      continue
    fi

    path=$(gt_worktree_for_branch "$name")
    if [[ -n "$path" ]]; then
      gt_say "skipping $name; checked out in worktree $path"
      skipped=$((skipped + 1))
      continue
    fi

    if [[ "$_dry_run" == 1 ]]; then
      gt_say "would delete $name (merged)"
    else
      git branch -D "$name" >/dev/null
      gt_say "deleted $name (merged)"
    fi
    dropped=$((dropped + 1))
  done < <(git for-each-ref --format='%(refname:short)' refs/heads)

  if [[ "$_dry_run" == 1 ]]; then
    gt_say "done; would delete $dropped branch(es), skipped $skipped"
  else
    gt_say "done; deleted $dropped branch(es), skipped $skipped"
  fi
}

gt_require_repo
_resolve_default

if [[ "$_drop_merged" == 1 ]]; then
  _drop
  exit 0
fi

gt_pr_load
_list
