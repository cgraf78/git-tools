#!/usr/bin/env bash
# Land a linear stack of ready GitHub pull requests.

set -euo pipefail

# shellcheck disable=SC2034 # consumed by lib/git-tools-pr.sh after dynamic source
gt_command="git pr-land-stack"

_script_path="${BASH_SOURCE[0]}"
while [[ -L "$_script_path" ]]; do
  _script_dir=$(cd -P -- "$(dirname -- "$_script_path")" && pwd)
  _link=$(readlink "$_script_path")
  case "$_link" in
    /*) _script_path="$_link" ;;
    *) _script_path="$_script_dir/$_link" ;;
  esac
done
_root=$(cd -P -- "$(dirname -- "$_script_path")/.." && pwd)
# shellcheck disable=SC1091
. "$_root/lib/git-tools-pr.sh"

_tool_tmp=""
_cleanup_tools() {
  [[ -z "$_tool_tmp" ]] || rm -rf "$_tool_tmp"
}

_snapshot_tool_dir() {
  [[ -z "${GIT_TOOLS_TOOL_DIR:-}" ]] || {
    _tool_dir="$GIT_TOOLS_TOOL_DIR"
    return 0
  }

  # `git pr-land` switches the checkout to the landing base after each merge.
  # Keep the helper implementations stable for the whole orchestration instead
  # of reading whatever files happen to exist after those branch switches.
  _tool_tmp=$(mktemp -d)
  mkdir -p "$_tool_tmp/bin" "$_tool_tmp/lib"
  cp "$_root/bin/git-pr-land" "$_tool_tmp/bin/git-pr-land"
  cp "$_root/bin/git-pr-restack" "$_tool_tmp/bin/git-pr-restack"
  cp "$_root/bin/git-pr-stack" "$_tool_tmp/bin/git-pr-stack"
  cp "$_root/lib/git-tools-pr.sh" "$_tool_tmp/lib/git-tools-pr.sh"
  _tool_dir="$_tool_tmp/bin"
}

trap _cleanup_tools EXIT
_tool_dir=""
_snapshot_tool_dir

_usage() {
  cat <<'EOF'
Usage: git pr-land-stack [options] <number|url|branch>

Land a linear stack of ready GitHub PRs from parent to child. The command is a
thin orchestrator over git pr-stack, git pr-land, and git pr-restack.

Options:
  -m, --method <method>   Merge method: squash, merge, or rebase (default: squash).
      --keep-branch       Pass --keep-branch to git pr-land.
      --check-timeout <s>  Seconds to wait after restacking for checks (default: 900).
      --check-interval <s> Seconds between check polls (default: 10).
  -n, --dry-run           Print actions without changing anything.
  -h, --help              Show this help.

Exit status:
  0  Stack was landed.
  1  Stack is not ready or a child restack/merge failed.
  2  Usage or local environment error.
EOF
}

_target=""
_method="squash"
_keep_branch=0
_dry_run=0
_check_timeout=900
_check_interval=10

# Invoke a sub-tool that understands --dry-run (git pr-land / pr-restack). The
# caller appends --dry-run, so the sub-tool self-describes; we always execute it,
# including in dry-run, where the sub-tool emits its own plan rather than acting.
_run_tool() {
  if [[ "$_dry_run" == 1 ]]; then
    printf 'git pr-land-stack: would run:' >&2
    printf ' %q' "$@" >&2
    printf '\n' >&2
  fi
  "$@"
}

# Run a raw command that has no dry-run mode of its own (e.g. git branch -D in
# _delete_landed_head). Unlike _run_tool, this MUST NOT fall through in dry-run —
# otherwise a dry run would force-delete stack branches locally and remotely.
_run_local() {
  if [[ "$_dry_run" == 1 ]]; then
    printf 'git pr-land-stack: would run:' >&2
    printf ' %q' "$@" >&2
    printf '\n' >&2
    return 0
  fi
  "$@"
}

_remote_for_branch() {
  local branch="$1"
  local remote

  remote=$(git config "branch.$branch.remote" 2>/dev/null || true)
  if [[ -n "$remote" ]]; then
    printf '%s\n' "$remote"
    return 0
  fi
  printf 'origin\n'
}

_local_branch_exists() {
  git show-ref --verify --quiet "refs/heads/$1"
}

_remote_branch_exists() {
  local remote="$1"
  local branch="$2"
  git show-ref --verify --quiet "refs/remotes/$remote/$branch"
}

_delete_landed_head() {
  local head="$1"
  local remote

  [[ "$_keep_branch" == 0 ]] || return 0

  # In a stack, a parent PR branch is still the next PR's base until after that
  # child has been restacked. Deleting it as part of the merge makes GitHub close
  # the child PR. Clean it up only once the child no longer points at it.
  remote=$(_remote_for_branch "$head")
  if _remote_branch_exists "$remote" "$head"; then
    _run_local git push "$remote" --delete "$head"
  fi
  if _local_branch_exists "$head"; then
    _run_local git branch -D "$head"
  fi
}

_require_positive_integer() {
  local name="$1"
  local value="$2"

  case "$value" in
    '' | *[!0-9]*)
      gt_usage_error "$name must be a positive integer"
      ;;
    0)
      gt_usage_error "$name must be greater than zero"
      ;;
  esac
}

_wait_for_ready_pr() {
  local target="$1"
  local elapsed=0
  local checks checks_state view
  local state draft merge_state

  [[ "$_dry_run" == 0 ]] || return 0

  while :; do
    view=$(gt_pr_view_tsv "$target") ||
      gt_die "could not read PR #$target after restack"
    IFS=$'\t' read -r _ state draft merge_state _ _ _ _ <<<"$view"

    checks=$(gt_pr_checks_status "$target") ||
      gt_die "could not read checks for PR #$target"
    checks_state=$(gt_checks_ready_state "$checks")

    if [[ "$state" != "OPEN" ]]; then
      gt_die "PR #$target is no longer open after restack"
    elif gt_bool "$draft"; then
      gt_die "PR #$target is a draft after restack"
    elif [[ "$checks_state" == "fail" ]]; then
      gt_die "PR #$target checks failed after restack"
    elif [[ "$merge_state" == "CLEAN" && "$checks_state" == "pass" ]]; then
      gt_say "PR #$target is ready after restack"
      return 0
    fi

    case "$checks_state" in
      none | pending | pass)
        ;;
      *)
        gt_die "unexpected checks state for PR #$target: $checks_state"
        ;;
    esac

    case "$merge_state" in
      BLOCKED | CLEAN | DIRTY | HAS_HOOKS | UNKNOWN | UNSTABLE)
        ;;
      *)
        gt_die "unexpected merge state for PR #$target after restack: $merge_state"
        ;;
    esac

    if ((elapsed >= _check_timeout)); then
      gt_die "timed out waiting for PR #$target after restack: merge $merge_state, checks $checks_state"
    fi
    gt_say "waiting for PR #$target after restack: merge $merge_state, checks $checks_state"
    sleep "$_check_interval"
    elapsed=$((elapsed + _check_interval))
  done
}

while (($#)); do
  case "$1" in
    -m | --method)
      _opt="$1"
      shift
      (($#)) || gt_usage_error "$_opt requires a value"
      _method="$1"
      shift
      ;;
    --method=*)
      _method="${1#--method=}"
      [[ -n "$_method" ]] || gt_usage_error "--method requires a value"
      shift
      ;;
    --keep-branch)
      _keep_branch=1
      shift
      ;;
    --check-timeout)
      _opt="$1"
      shift
      (($#)) || gt_usage_error "$_opt requires a value"
      _check_timeout="$1"
      shift
      ;;
    --check-timeout=*)
      _check_timeout="${1#--check-timeout=}"
      [[ -n "$_check_timeout" ]] || gt_usage_error "--check-timeout requires a value"
      shift
      ;;
    --check-interval)
      _opt="$1"
      shift
      (($#)) || gt_usage_error "$_opt requires a value"
      _check_interval="$1"
      shift
      ;;
    --check-interval=*)
      _check_interval="${1#--check-interval=}"
      [[ -n "$_check_interval" ]] || gt_usage_error "--check-interval requires a value"
      shift
      ;;
    -n | --dry-run)
      _dry_run=1
      shift
      ;;
    -h | --help)
      _usage
      exit 0
      ;;
    --)
      shift
      (($# == 1)) || gt_usage_error "expected exactly one target"
      _target="$1"
      break
      ;;
    -*)
      gt_usage_error "unexpected option: $1"
      ;;
    *)
      [[ -z "$_target" ]] || gt_usage_error "expected exactly one target"
      _target="$1"
      shift
      ;;
  esac
done

[[ -n "$_target" ]] || gt_usage_error "expected exactly one target"
case "$_method" in
  squash | merge | rebase) ;;
  *) gt_usage_error "merge method must be squash, merge, or rebase" ;;
esac
_require_positive_integer "--check-timeout" "$_check_timeout"
_require_positive_integer "--check-interval" "$_check_interval"

gt_require_repo
gt_require_gh
if [[ "$_dry_run" != 1 ]]; then
  gt_require_clean_worktree
fi

_stack_output=$("$_tool_dir/git-pr-stack" "$_target" --porcelain) ||
  gt_die "could not discover stack"

_records=()
while IFS= read -r _line; do
  [[ -n "$_line" ]] || continue
  _records+=("$_line")
done <<<"$_stack_output"

((${#_records[@]} > 0)) || gt_die "stack is empty"

_numbers=()
_bases=()
_heads=()
_ready=()
_reasons=()

for _record in "${_records[@]}"; do
  IFS=$'\t' read -r _kind _index _number _base _head _is_ready _reason _checks _url <<<"$_record"
  [[ "$_kind" == "pr" ]] || gt_die "unexpected pr-stack record: $_record"
  _numbers+=("$_number")
  _bases+=("$_base")
  _heads+=("$_head")
  _ready+=("$_is_ready")
  _reasons+=("$_reason")
done

for _i in "${!_numbers[@]}"; do
  if [[ "${_ready[$_i]}" != true ]]; then
    gt_die "PR #${_numbers[$_i]} is not ready: ${_reasons[$_i]}"
  fi
done

gt_say "landing ${#_numbers[@]} PR(s)"

_land_base="${_bases[0]}"

for _i in "${!_numbers[@]}"; do
  _number="${_numbers[$_i]}"
  _next_index=$((_i + 1))

  _land_args=("$_tool_dir/git-pr-land" "$_number" --method "$_method")
  if [[ "$_keep_branch" == 1 || $_next_index -lt ${#_numbers[@]} ]]; then
    _land_args+=(--keep-branch)
  fi
  if [[ "$_dry_run" == 1 ]]; then
    _land_args+=(--dry-run)
  fi

  _run_tool "${_land_args[@]}"

  if ((_next_index < ${#_numbers[@]})); then
    _child="${_numbers[$_next_index]}"
    # The just-landed parent's head is the child's old base. Pass it as the fork
    # point so the parent's commits drop out of the child instead of being
    # re-applied onto the root base (which conflicts after a squash merge). The
    # parent branch still exists here; _delete_landed_head removes it below.
    _restack_args=("$_tool_dir/git-pr-restack" "$_child" --base "$_land_base" --fork "${_heads[$_i]}")
    if [[ "$_dry_run" == 1 ]]; then
      _restack_args+=(--dry-run)
    fi
    _run_tool "${_restack_args[@]}"
    _wait_for_ready_pr "$_child"
    _delete_landed_head "${_heads[$_i]}"
  fi
done

gt_say "landed stack rooted at PR #${_numbers[0]}"
