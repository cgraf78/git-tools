#!/usr/bin/env bash
# Push the current branch and create a GitHub pull request non-interactively.

set -euo pipefail

# shellcheck disable=SC2034 # consumed by lib/git-tools-pr.sh after dynamic source
gt_command="git pr-open"

_script_path="${BASH_SOURCE[0]}"
while [[ -L "$_script_path" ]]; do
  _script_dir=$(cd -P -- "$(dirname -- "$_script_path")" && pwd)
  _link=$(readlink "$_script_path")
  case "$_link" in
    /*) _script_path="$_link" ;;
    *) _script_path="$_script_dir/$_link" ;;
  esac
done
_root=$(cd -P -- "$(dirname -- "$_script_path")/.." && pwd)
# shellcheck disable=SC1091
. "$_root/lib/git-tools-pr.sh"

_usage() {
  cat <<'EOF'
Usage: git pr-open [options]

Push the current branch with upstream tracking and create a GitHub pull request
without interactive prompts.

Options:
  -t, --title <title>       Pull request title.
  -b, --body <body>         Pull request body.
  -F, --body-file <file>    Read pull request body from file.
  -B, --base <branch>       Base branch (default: repository default branch).
  -H, --head <branch>       Head branch name for GitHub (default: current branch).
  -d, --draft               Create a draft pull request.
      --fill                Use commit info for title and body.
      --fill-first          Use first commit info for title and body.
      --fill-verbose        Use commit messages and bodies for description.
      --no-maintainer-edit  Disable maintainer edits.
  -n, --dry-run             Print actions without changing anything.
  -h, --help                Show this help.

Exit status:
  0  Pull request was created, or dry-run completed.
  1  Pull request creation failed.
  2  Usage or local environment error.
EOF
}

_title=""
_body=""
_body_file=""
_base=""
_head=""
_draft=0
_fill=""
_maintainer_edit=1
_dry_run=0

while (($#)); do
  case "$1" in
    -t | --title)
      _opt="$1"
      shift
      (($#)) || gt_usage_error "$_opt requires a value"
      _title="$1"
      shift
      ;;
    --title=*)
      _title="${1#--title=}"
      [[ -n "$_title" ]] || gt_usage_error "--title requires a value"
      shift
      ;;
    -b | --body)
      _opt="$1"
      shift
      (($#)) || gt_usage_error "$_opt requires a value"
      _body="$1"
      shift
      ;;
    --body=*)
      _body="${1#--body=}"
      shift
      ;;
    -F | --body-file)
      _opt="$1"
      shift
      (($#)) || gt_usage_error "$_opt requires a value"
      _body_file="$1"
      shift
      ;;
    --body-file=*)
      _body_file="${1#--body-file=}"
      [[ -n "$_body_file" ]] || gt_usage_error "--body-file requires a value"
      shift
      ;;
    -B | --base)
      _opt="$1"
      shift
      (($#)) || gt_usage_error "$_opt requires a value"
      _base="$1"
      shift
      ;;
    --base=*)
      _base="${1#--base=}"
      [[ -n "$_base" ]] || gt_usage_error "--base requires a value"
      shift
      ;;
    -H | --head)
      _opt="$1"
      shift
      (($#)) || gt_usage_error "$_opt requires a value"
      _head="$1"
      shift
      ;;
    --head=*)
      _head="${1#--head=}"
      [[ -n "$_head" ]] || gt_usage_error "--head requires a value"
      shift
      ;;
    -d | --draft)
      _draft=1
      shift
      ;;
    --fill | --fill-first | --fill-verbose)
      [[ -z "$_fill" ]] || gt_usage_error "only one fill mode may be used"
      _fill="$1"
      shift
      ;;
    --no-maintainer-edit)
      _maintainer_edit=0
      shift
      ;;
    -n | --dry-run)
      _dry_run=1
      shift
      ;;
    -h | --help)
      _usage
      exit 0
      ;;
    -*)
      gt_usage_error "unexpected option: $1"
      ;;
    *)
      gt_usage_error "unexpected argument: $1"
      ;;
  esac
done

[[ -z "$_body" || -z "$_body_file" ]] ||
  gt_usage_error "--body and --body-file cannot be used together"
[[ -n "$_title" || -n "$_fill" ]] ||
  gt_usage_error "--title is required unless a --fill mode is used"

_run() {
  if [[ "$_dry_run" == 1 ]]; then
    printf 'git pr-open: would run:' >&2
    printf ' %q' "$@" >&2
    printf '\n' >&2
    return 0
  fi
  "$@"
}

_default_branch() {
  local ref

  ref=$(git symbolic-ref -q --short refs/remotes/origin/HEAD 2>/dev/null || true)
  if [[ -n "$ref" ]]; then
    printf '%s\n' "${ref#origin/}"
    return 0
  fi

  for ref in origin/main origin/master origin/trunk; do
    if git show-ref --verify --quiet "refs/remotes/$ref"; then
      printf '%s\n' "${ref#origin/}"
      return 0
    fi
  done

  for ref in main master trunk; do
    if git show-ref --verify --quiet "refs/heads/$ref"; then
      printf '%s\n' "$ref"
      return 0
    fi
  done

  printf 'main\n'
}

_remote_for_branch() {
  local branch="$1"
  local remote

  remote=$(git config "branch.$branch.remote" 2>/dev/null || true)
  if [[ -n "$remote" ]]; then
    printf '%s\n' "$remote"
    return 0
  fi
  printf 'origin\n'
}

_remote_branch_exists() {
  git show-ref --verify --quiet "refs/remotes/$1/$2"
}

_local_branch_exists() {
  git show-ref --verify --quiet "refs/heads/$1"
}

_ensure_base_current() {
  local remote="$1"
  local base="$2"

  _run git fetch --quiet --prune --tags "$remote"

  _remote_branch_exists "$remote" "$base" ||
    gt_die "base branch does not exist on $remote: $base"

  if _local_branch_exists "$base"; then
    _local=$(git rev-parse "$base")
    _remote_ref=$(git rev-parse "$remote/$base")
    [[ "$_local" == "$_remote_ref" ]] ||
      gt_die "local base branch is stale: $base differs from $remote/$base"
  fi
}

gt_require_repo
gt_require_gh
gt_require_clean_worktree

_branch=$(gt_current_branch)
_base="${_base:-$(_default_branch)}"
_head="${_head:-$_branch}"

[[ "$_branch" != "$_base" ]] ||
  gt_usage_error "current branch is the base branch: $_base"

_remote=$(_remote_for_branch "$_base")
_ensure_base_current "$_remote" "$_base"

_run git push -u "$_remote" "$_branch"

_create_args=(pr create --base "$_base" --head "$_head")
[[ "$_draft" == 0 ]] || _create_args+=(--draft)
[[ "$_maintainer_edit" == 1 ]] || _create_args+=(--no-maintainer-edit)
[[ "$_dry_run" == 0 ]] || _create_args+=(--dry-run)

if [[ -n "$_fill" ]]; then
  _create_args+=("$_fill")
else
  _create_args+=(--title "$_title")
  if [[ -n "$_body_file" ]]; then
    _create_args+=(--body-file "$_body_file")
  else
    _create_args+=(--body "$_body")
  fi
fi

_run gh "${_create_args[@]}"
