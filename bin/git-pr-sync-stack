#!/usr/bin/env bash
# Restack every PR in a linear stack without merging anything.

set -euo pipefail

# shellcheck disable=SC2034 # consumed by lib/git-tools-pr.sh after dynamic source
gt_command="git pr-sync-stack"

_script_path="${BASH_SOURCE[0]}"
while [[ -L "$_script_path" ]]; do
  _script_dir=$(cd -P -- "$(dirname -- "$_script_path")" && pwd)
  _link=$(readlink "$_script_path")
  case "$_link" in
    /*) _script_path="$_link" ;;
    *) _script_path="$_script_dir/$_link" ;;
  esac
done
_root=$(cd -P -- "$(dirname -- "$_script_path")/.." && pwd)
# shellcheck disable=SC1091
. "$_root/lib/git-tools-pr.sh"

_usage() {
  cat <<'EOF'
Usage: git pr-sync-stack [options] [<number|url|branch>]

Restack every pull request in a linear stack, parent-to-child, without merging
anything. Without a target, uses the PR for the current branch.

Options:
  -b, --base <branch>   Rebase the root PR onto this base branch.
      --no-push         Rebase locally without pushing or editing PR bases.
  -n, --dry-run         Print actions without changing anything.
  -h, --help            Show this help.

Exit status:
  0  Stack was synced.
  1  Stack discovery or restack failed.
  2  Usage or local environment error.
EOF
}

_target=""
_base_override=""
_push=1
_dry_run=0

while (($#)); do
  case "$1" in
    -b | --base)
      _opt="$1"
      shift
      (($#)) || gt_usage_error "$_opt requires a value"
      _base_override="$1"
      shift
      ;;
    --base=*)
      _base_override="${1#--base=}"
      [[ -n "$_base_override" ]] || gt_usage_error "--base requires a value"
      shift
      ;;
    --no-push)
      _push=0
      shift
      ;;
    -n | --dry-run)
      _dry_run=1
      shift
      ;;
    -h | --help)
      _usage
      exit 0
      ;;
    --)
      shift
      (($# <= 1)) || gt_usage_error "expected at most one target"
      _target="${1:-}"
      break
      ;;
    -*)
      gt_usage_error "unexpected option: $1"
      ;;
    *)
      [[ -z "$_target" ]] || gt_usage_error "expected at most one target"
      _target="$1"
      shift
      ;;
  esac
done

_run() {
  if [[ "$_dry_run" == 1 ]]; then
    printf 'git pr-sync-stack: would run:' >&2
    printf ' %q' "$@" >&2
    printf '\n' >&2
  fi
  "$@"
}

_restack() {
  local number="$1"
  local base="$2"
  local -a args=(git pr-restack "$number" --base "$base")

  [[ "$_push" == 1 ]] || args+=(--no-push)
  [[ "$_dry_run" == 0 ]] || args+=(--dry-run)

  gt_say "restacking PR #$number onto $base"
  _run "${args[@]}"
}

gt_require_repo

_stack_args=(git pr-stack --porcelain)
[[ -z "$_target" ]] || _stack_args+=("$_target")

_stack_output=$("${_stack_args[@]}") || gt_die "could not read pull request stack"

_numbers=()
_bases=()
_heads=()

while IFS=$'\t' read -r _kind _index _number _base _head _ready _reason _checks _url; do
  [[ "$_kind" == "pr" ]] || continue
  _numbers+=("$_number")
  _bases+=("$_base")
  _heads+=("$_head")
done <<<"$_stack_output"

((${#_numbers[@]} > 0)) || gt_die "no pull requests found in stack"

_index=0
while ((_index < ${#_numbers[@]})); do
  if ((_index == 0)); then
    _base="${_base_override:-${_bases[$_index]}}"
  else
    _base="${_heads[$((_index - 1))]}"
  fi

  _restack "${_numbers[$_index]}" "$_base"
  _index=$((_index + 1))
done

gt_say "synced ${#_numbers[@]} PR(s)"
