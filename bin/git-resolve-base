#!/usr/bin/env bash
# Print the inferred branch point of the current branch.

set -euo pipefail

# shellcheck disable=SC2034 # consumed by lib/git-tools-pr.sh after dynamic source
gt_command="git resolve-base"

_script_path="${BASH_SOURCE[0]}"
while [[ -L "$_script_path" ]]; do
  _script_dir=$(cd -P -- "$(dirname -- "$_script_path")" && pwd)
  _link=$(readlink "$_script_path")
  case "$_link" in
    /*) _script_path="$_link" ;;
    *) _script_path="$_script_dir/$_link" ;;
  esac
done
_root=$(cd -P -- "$(dirname -- "$_script_path")/.." && pwd)
# shellcheck disable=SC1091
. "$_root/lib/git-tools-pr.sh"
# shellcheck disable=SC1091
. "$_root/lib/git-tools-base.sh"

_usage() {
  cat <<'EOF'
Usage: git resolve-base [options]

Resolve the branch point the current branch diverged from and print it. The
base ref is inferred in order: the configured upstream, a remote default branch
(origin/HEAD and friends), then a local default branch (main/master/trunk).

By default this prints the merge-base commit (the branch point). Use --ref to
print the base ref that resolution selected instead.

Options:
      --ref           Print the resolved base ref instead of the merge-base commit.
      --short         Abbreviate the merge-base commit id.
  -h, --help          Show this help.

Exit status:
  0  Base resolved and printed.
  2  Usage error, not in a repository, or base could not be determined.
EOF
}

_ref=0
_short=0

while (($#)); do
  case "$1" in
    --ref)
      _ref=1
      shift
      ;;
    --short)
      _short=1
      shift
      ;;
    -h | --help)
      _usage
      exit 0
      ;;
    --)
      shift
      (($# == 0)) || gt_usage_error "unexpected argument: $1"
      ;;
    -*)
      gt_usage_error "unexpected option: $1"
      ;;
    *)
      gt_usage_error "unexpected argument: $1"
      ;;
  esac
done

[[ "$_ref" == 0 || "$_short" == 0 ]] ||
  gt_usage_error "--short applies to the commit output and cannot be combined with --ref"

gt_require_repo
git symbolic-ref -q --short HEAD >/dev/null ||
  gt_usage_error "detached HEAD has no branch point"

_resolved=$(gt_resolve_base) ||
  gt_usage_error "could not determine branch base"

_base_ref=${_resolved%%$'\t'*}
_base_commit=${_resolved#*$'\t'}

if [[ "$_ref" == 1 ]]; then
  printf '%s\n' "$_base_ref"
  exit 0
fi

if [[ "$_short" == 1 ]]; then
  git rev-parse --short "$_base_commit"
else
  printf '%s\n' "$_base_commit"
fi
