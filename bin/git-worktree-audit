#!/usr/bin/env bash
# Report state across all worktrees, and optionally prune orphaned ones.

set -euo pipefail

# shellcheck disable=SC2034 # consumed by lib/git-tools-pr.sh after dynamic source
gt_command="git worktree-audit"

_script_path="${BASH_SOURCE[0]}"
while [[ -L "$_script_path" ]]; do
  _script_dir=$(cd -P -- "$(dirname -- "$_script_path")" && pwd)
  _link=$(readlink "$_script_path")
  case "$_link" in
    /*) _script_path="$_link" ;;
    *) _script_path="$_script_dir/$_link" ;;
  esac
done
_root=$(cd -P -- "$(dirname -- "$_script_path")/.." && pwd)
# shellcheck disable=SC1091
. "$_root/lib/git-tools-pr.sh"
# shellcheck disable=SC1091
. "$_root/lib/git-tools-base.sh"

_usage() {
  cat <<'EOF'
Usage: git worktree-audit [options]

List every worktree with its path, checked-out branch, dirty state, last commit
age, and the open PR number when GitHub data is available. Worktrees whose
directory no longer exists are reported as orphans.

Options:
      --porcelain        Print stable tab-separated worktree records.
      --prune-orphan     Prune worktrees whose directory no longer exists.
  -n, --dry-run          With --prune-orphan, print what would be pruned.
  -h, --help             Show this help.

Exit status:
  0  Audit or prune completed.
  2  Usage or local environment error.
EOF
}

_porcelain=0
_prune_orphan=0
_dry_run=0

while (($#)); do
  case "$1" in
    --porcelain)
      _porcelain=1
      shift
      ;;
    --prune-orphan)
      _prune_orphan=1
      shift
      ;;
    -n | --dry-run)
      _dry_run=1
      shift
      ;;
    -h | --help)
      _usage
      exit 0
      ;;
    -*)
      gt_usage_error "unexpected option: $1"
      ;;
    *)
      gt_usage_error "unexpected argument: $1"
      ;;
  esac
done

# Classify the branch label for one worktree record.
_branch_label() {
  if [[ "$_wt_bare" == 1 ]]; then
    printf 'bare\n'
  elif [[ "$_wt_detached" == 1 || -z "$_wt_branch" ]]; then
    printf 'detached\n'
  else
    printf '%s\n' "${_wt_branch#refs/heads/}"
  fi
}

# Dirty state is unknowable for a bare or orphaned worktree because there is no
# working tree to inspect.
_dirty_state() {
  local orphan="$1"
  if [[ "$_wt_bare" == 1 || "$orphan" == true ]]; then
    printf 'unknown\n'
    return 0
  fi
  if [[ -n "$(git -C "$_wt_path" status --porcelain 2>/dev/null)" ]]; then
    printf 'true\n'
  else
    printf 'false\n'
  fi
}

_emit() {
  [[ -n "$_wt_path" ]] || return 0

  local branch dirty orphan pr rel unix
  branch=$(_branch_label)

  orphan=false
  # git marks vanished worktrees prunable; also treat a missing directory as
  # orphaned in case metadata has not caught up yet.
  if [[ "$_wt_prunable" == 1 || ! -d "$_wt_path" ]]; then
    orphan=true
  fi

  dirty=$(_dirty_state "$orphan")

  pr=""
  case "$branch" in
    bare | detached) ;;
    *) pr=$(gt_pr_number_for_branch "$branch" || true) ;;
  esac

  rel=""
  unix=""
  if [[ -n "$_wt_head" ]]; then
    rel=$(git show -s --format=%cr "$_wt_head" 2>/dev/null || true)
    unix=$(git show -s --format=%ct "$_wt_head" 2>/dev/null || true)
  fi

  if [[ "$_porcelain" == 1 ]]; then
    printf 'worktree\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
      "$_wt_path" "$branch" "$dirty" "$orphan" "$pr" "$_wt_head" "$unix"
  else
    printf '%s branch=%s dirty=%s orphan=%s' "$_wt_path" "$branch" "$dirty" "$orphan"
    [[ -z "$pr" ]] || printf ' pr=#%s' "$pr"
    [[ -z "$rel" ]] || printf ' (%s)' "$rel"
    printf '\n'
  fi
}

_reset_record() {
  _wt_path=""
  _wt_head=""
  _wt_branch=""
  _wt_bare=0
  _wt_detached=0
  _wt_prunable=0
}

_list() {
  _reset_record

  # Each record begins with a "worktree " line. Flush the previous record when
  # the next one starts, then flush the final record after the loop, so parsing
  # does not depend on trailing blank lines.
  while IFS= read -r line; do
    case "$line" in
      "worktree "*)
        _emit
        _reset_record
        _wt_path=${line#worktree }
        ;;
      "HEAD "*) _wt_head=${line#HEAD } ;;
      "branch "*) _wt_branch=${line#branch } ;;
      "detached") _wt_detached=1 ;;
      "bare") _wt_bare=1 ;;
      "prunable"*) _wt_prunable=1 ;;
    esac
  done < <(git worktree list --porcelain)

  _emit
}

_prune() {
  if [[ "$_dry_run" == 1 ]]; then
    git worktree prune --dry-run --verbose
  else
    git worktree prune --verbose
  fi
}

gt_require_repo

if [[ "$_prune_orphan" == 1 ]]; then
  _prune
  exit 0
fi

gt_pr_load
_list
