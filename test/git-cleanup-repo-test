#!/usr/bin/env bash

set -uo pipefail

ROOT=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)
PATH="$ROOT/bin:$PATH"
export NO_COLOR=1

_failures=0
_temps=()

_tmpdir() {
  local dir
  dir=$(mktemp -d)
  _temps+=("$dir")
  printf '%s\n' "$dir"
}

_cleanup() {
  local dir
  for dir in "${_temps[@]}"; do
    rm -rf "$dir"
  done
}
trap _cleanup EXIT

_pass() {
  printf 'ok - %s\n' "$1"
}

_fail() {
  printf 'not ok - %s\n' "$1" >&2
  _failures=$((_failures + 1))
}

_assert_eq() {
  local name="$1"
  local expected="$2"
  local actual="$3"

  if [[ "$actual" == "$expected" ]]; then
    _pass "$name"
  else
    _fail "$name"
    printf '  expected: %q\n' "$expected" >&2
    printf '  actual:   %q\n' "$actual" >&2
  fi
}

_assert_contains() {
  local name="$1"
  local needle="$2"
  local haystack="$3"

  if [[ "$haystack" == *"$needle"* ]]; then
    _pass "$name"
  else
    _fail "$name"
    printf '  expected output to contain: %s\n' "$needle" >&2
    printf '  actual output:\n%s\n' "$haystack" >&2
  fi
}

_git_init() {
  local repo="$1"
  git init -q --initial-branch=main "$repo"
  git -C "$repo" config user.email "test@test.com"
  git -C "$repo" config user.name "Test"
  git -C "$repo" config core.hooksPath /dev/null
}

_commit_file() {
  local repo="$1"
  local path="$2"
  local content="$3"
  local message="$4"

  mkdir -p "$(dirname "$repo/$path")"
  printf '%s\n' "$content" >"$repo/$path"
  git -C "$repo" add "$path"
  git -C "$repo" commit -m "$message" >/dev/null
}

_clone_remote() {
  local remote repo

  remote=$(_tmpdir)
  repo=$(_tmpdir)
  git init --bare --initial-branch=main "$remote" >/dev/null
  _git_init "$repo"
  _commit_file "$repo" README.md base base
  git -C "$repo" remote add origin "$remote"
  git -C "$repo" push -u origin main >/dev/null 2>&1
  printf '%s\n' "$repo"
}

_branches() {
  local repo="$1"
  git -C "$repo" branch --format='%(refname:short)' | sort
}

echo "=== git cleanup-repo ==="

repo=$(_clone_remote)
git -C "$repo" switch --quiet -c merged
_commit_file "$repo" merged.txt merged "add merged"
git -C "$repo" switch --quiet main
git -C "$repo" merge --no-ff merged -m "merge merged" >/dev/null

git -C "$repo" switch --quiet -c gone
_commit_file "$repo" gone.txt gone "add gone"
git -C "$repo" push -u origin gone >/dev/null 2>&1
git -C "$repo" switch --quiet main
git -C "$repo" push origin --delete gone >/dev/null 2>&1

git -C "$repo" switch --quiet -c keep
_commit_file "$repo" keep.txt keep "add keep"
git -C "$repo" push -u origin keep >/dev/null 2>&1
git -C "$repo" switch --quiet main

result=$(git -C "$repo" cleanup-repo 2>&1)
_assert_contains "reports deleted branches" "deleted 1 branch(es), skipped 2" "$result"
expected="$(printf 'gone\nkeep\nmain')"
_assert_eq "deletes only merged branches by default" "$expected" "$(_branches "$repo")"
result=$(git -C "$repo" cleanup-repo --gone 2>&1)
_assert_contains "gone deletes branches with removed upstreams" \
  "deleting gone (upstream gone)" "$result"
expected="$(printf 'keep\nmain')"
_assert_eq "gone leaves unmerged branches with live upstreams" "$expected" "$(_branches "$repo")"

squash_repo=$(_clone_remote)
git -C "$squash_repo" switch --quiet -c squashed
_commit_file "$squash_repo" squashed.txt one "add squashed step 1"
_commit_file "$squash_repo" squashed.txt two "edit squashed step 2"
git -C "$squash_repo" switch --quiet main
# Simulate a squash merge: the branch's net change applied as ONE new commit on
# main with a different commit id, exactly what GitHub's squash merge produces.
# The branch tip is not an ancestor of main, so only patch-id detection finds it.
printf '%s\n' two >"$squash_repo/squashed.txt"
git -C "$squash_repo" add squashed.txt
git -C "$squash_repo" commit --quiet -m "squashed (#1)" >/dev/null
result=$(git -C "$squash_repo" cleanup-repo 2>&1)
_assert_contains "default deletes squash-merged branches" \
  "deleting squashed (content-merged)" "$result"
_assert_eq "squash-merged branch removed by default" "main" "$(_branches "$squash_repo")"

rebase_repo=$(_clone_remote)
git -C "$rebase_repo" switch --quiet -c rebased
_commit_file "$rebase_repo" r1.txt one "rebased step 1"
_commit_file "$rebase_repo" r2.txt two "rebased step 2"
git -C "$rebase_repo" switch --quiet main
# main advances independently first (as it has by the time a PR lands), so the
# replayed commits get new ids and the branch tip is definitively not an
# ancestor of main. Without this, cherry-pick can reproduce byte-identical SHAs
# (same content + same-second committer date) and the branch would be detected
# as a plain ancestor merge instead of a content (patch-id) merge.
_commit_file "$rebase_repo" mainline.txt main "unrelated mainline commit"
# Simulate a rebase merge: each branch commit replayed onto main as a NEW commit.
# The collapsed-diff probe will not match, but every commit's patch-id is
# present, which the per-commit check detects.
git -C "$rebase_repo" cherry-pick rebased~1 rebased >/dev/null 2>&1
result=$(git -C "$rebase_repo" cleanup-repo 2>&1)
_assert_contains "default deletes multi-commit rebase-merged branches" \
  "deleting rebased (content-merged)" "$result"
_assert_eq "rebase-merged branch removed by default" "main" "$(_branches "$rebase_repo")"

unmerged_repo=$(_clone_remote)
git -C "$unmerged_repo" switch --quiet -c partial
_commit_file "$unmerged_repo" partial.txt one "add partial step 1"
git -C "$unmerged_repo" switch --quiet main
# Only part of the branch's diff is on main (a different file), so the patch-id
# check must NOT consider it merged and the branch must be kept by default.
_commit_file "$unmerged_repo" other.txt other "add unrelated commit"
result=$(git -C "$unmerged_repo" cleanup-repo 2>&1)
_assert_contains "keeps branches that are not content-merged" \
  "keeping partial; not merged" "$result"
_assert_eq "unmerged branch survives default cleanup" \
  "$(printf 'main\npartial')" "$(_branches "$unmerged_repo")"

# Any unmerged content must keep the branch, even when some of it landed. A
# rebase that replayed only the first commit leaves a second commit unmerged.
rebase_partial_repo=$(_clone_remote)
git -C "$rebase_partial_repo" switch --quiet -c rebased-extra
_commit_file "$rebase_partial_repo" re1.txt one "rebased-extra step 1"
_commit_file "$rebase_partial_repo" re2.txt two "rebased-extra step 2"
git -C "$rebase_partial_repo" switch --quiet main
git -C "$rebase_partial_repo" cherry-pick rebased-extra~1 >/dev/null 2>&1
result=$(git -C "$rebase_partial_repo" cleanup-repo 2>&1)
_assert_contains "keeps a partially rebase-merged branch with an extra commit" \
  "keeping rebased-extra; not merged" "$result"
_assert_eq "partially rebase-merged branch survives" \
  "$(printf 'main\nrebased-extra')" "$(_branches "$rebase_partial_repo")"

# Squash-merge the branch's first commits, then add one more commit that was
# never merged. The collapsed-diff probe will not match (extra content) and the
# per-commit check sees the unmerged commit, so the branch must be kept.
squash_partial_repo=$(_clone_remote)
git -C "$squash_partial_repo" switch --quiet -c squashed-extra
_commit_file "$squash_partial_repo" se1.txt one "squashed-extra step 1"
_commit_file "$squash_partial_repo" se2.txt two "squashed-extra step 2"
git -C "$squash_partial_repo" switch --quiet main
printf '%s\n' one >"$squash_partial_repo/se1.txt"
printf '%s\n' two >"$squash_partial_repo/se2.txt"
git -C "$squash_partial_repo" add se1.txt se2.txt
git -C "$squash_partial_repo" commit --quiet -m "squashed-extra (#1)"
git -C "$squash_partial_repo" switch --quiet squashed-extra
_commit_file "$squash_partial_repo" se3.txt three "squashed-extra step 3 (unmerged)"
git -C "$squash_partial_repo" switch --quiet main
result=$(git -C "$squash_partial_repo" cleanup-repo 2>&1)
_assert_contains "keeps a squash-merged branch with an extra unmerged commit" \
  "keeping squashed-extra; not merged" "$result"
_assert_eq "squash-merged branch with extra work survives" \
  "$(printf 'main\nsquashed-extra')" "$(_branches "$squash_partial_repo")"

dry_repo=$(_clone_remote)
git -C "$dry_repo" switch --quiet -c dry
_commit_file "$dry_repo" dry.txt dry "add dry"
git -C "$dry_repo" switch --quiet main
git -C "$dry_repo" merge --no-ff dry -m "merge dry" >/dev/null
result=$(git -C "$dry_repo" cleanup-repo --dry-run 2>&1)
_assert_contains "dry run reports branch deletion" "deleting dry (merged)" "$result"
_assert_contains "dry run reports would-delete summary" "would delete 1 branch(es)" "$result"
expected="$(printf 'dry\nmain')"
_assert_eq "dry run keeps branches" "$expected" "$(_branches "$dry_repo")"

all_repo=$(_clone_remote)
git -C "$all_repo" switch --quiet -c unmerged
_commit_file "$all_repo" unmerged.txt unmerged "add unmerged"
git -C "$all_repo" push -u origin unmerged >/dev/null 2>&1
git -C "$all_repo" switch --quiet main
result=$(git -C "$all_repo" cleanup-repo --all 2>&1)
_assert_contains "all deletes unmerged local branches" "deleting unmerged (all)" "$result"
_assert_eq "all leaves only main" "main" "$(_branches "$all_repo")"

worktree_repo=$(_clone_remote)
git -C "$worktree_repo" switch --quiet -c work
_commit_file "$worktree_repo" work.txt work "add work"
git -C "$worktree_repo" switch --quiet main
worktree_dir=$(_tmpdir)
rm -rf "$worktree_dir"
git -C "$worktree_repo" worktree add "$worktree_dir" work >/dev/null 2>&1
result=$(git -C "$worktree_repo" cleanup-repo --all 2>&1)
_assert_contains "keeps checked-out branches without worktree removal" \
  "skipping work; checked out in worktree" "$result"
expected="$(printf 'main\nwork')"
_assert_eq "branch remains while worktree is kept" "$expected" "$(_branches "$worktree_repo")"
result=$(git -C "$worktree_repo" cleanup-repo --all --remove-worktrees 2>&1)
_assert_contains "removes clean linked worktrees" "deleting work (all)" "$result"
_assert_eq "worktree cleanup leaves only main" "main" "$(_branches "$worktree_repo")"

dirty_repo=$(_clone_remote)
printf 'dirty\n' >"$dirty_repo/dirty.txt"
result=$(git -C "$dirty_repo" cleanup-repo 2>&1 || true)
_assert_contains "refuses dirty worktrees" "worktree must be clean" "$result"
result=$(git -C "$dirty_repo" cleanup-repo --dry-run 2>&1)
_assert_contains "dry run can inspect dirty worktrees" \
  "real cleanup would stop before changing refs" "$result"

if ((_failures > 0)); then
  printf '%s failure(s)\n' "$_failures" >&2
  exit 1
fi

printf 'all tests passed\n'
