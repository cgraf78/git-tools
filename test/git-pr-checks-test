#!/usr/bin/env bash

set -uo pipefail

ROOT=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)
PATH="$ROOT/bin:$PATH"
export NO_COLOR=1

_failures=0
_temps=()

_tmpdir() {
  local dir
  dir=$(mktemp -d)
  _temps+=("$dir")
  printf '%s\n' "$dir"
}

_cleanup() {
  local dir
  for dir in "${_temps[@]}"; do
    rm -rf "$dir"
  done
}
trap _cleanup EXIT

_pass() {
  printf 'ok - %s\n' "$1"
}

_fail() {
  printf 'not ok - %s\n' "$1" >&2
  _failures=$((_failures + 1))
}

_assert_contains() {
  local name="$1"
  local needle="$2"
  local haystack="$3"

  if [[ "$haystack" == *"$needle"* ]]; then
    _pass "$name"
  else
    _fail "$name"
    printf '  expected output to contain: %s\n' "$needle" >&2
    printf '  actual output:\n%s\n' "$haystack" >&2
  fi
}

_assert_status() {
  local name="$1"
  local expected="$2"
  local actual="$3"

  if [[ "$actual" == "$expected" ]]; then
    _pass "$name"
  else
    _fail "$name"
    printf '  expected status: %s\n' "$expected" >&2
    printf '  actual status:   %s\n' "$actual" >&2
  fi
}

_git_init() {
  local repo="$1"
  git init -q --initial-branch=main "$repo"
  git -C "$repo" config user.email "test@test.com"
  git -C "$repo" config user.name "Test"
  git -C "$repo" config core.hooksPath /dev/null
  printf 'base\n' >"$repo/README.md"
  git -C "$repo" add README.md
  git -C "$repo" commit -m base >/dev/null
}

_write_gh_stub() {
  local bin="$1/gh"
  cat >"$bin" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail

printf '%s\n' "$*" >>"${GH_LOG:?}"

if [[ "$1 $2" == "auth status" ]]; then
  exit 0
fi

if [[ "$1 $2" == "pr checks" ]]; then
  if [[ "$*" == *"--watch"* ]]; then
    exit 0
  fi

  case "${GH_CHECK_CASE:-pass}" in
    pass)
      printf 'build\tpass\tSUCCESS\tci\thttps://example/check/build\n'
      printf 'lint\tpass\tSUCCESS\tci\thttps://example/check/lint\n'
      ;;
    pending)
      printf 'build\tpass\tSUCCESS\tci\thttps://example/check/build\n'
      printf 'lint\tpending\tQUEUED\tci\thttps://example/check/lint\n'
      exit 8
      ;;
    fail)
      printf 'build\tpass\tSUCCESS\tci\thttps://example/check/build\n'
      printf 'lint\tfail\tFAILURE\tci\thttps://example/check/lint\n'
      ;;
    none)
      printf "no checks reported on the 'feature/a' branch\n"
      exit 1
      ;;
  esac
  exit 0
fi

printf 'unexpected gh call: %s\n' "$*" >&2
exit 99
EOF
  chmod +x "$bin"
}

echo "=== git pr-checks ==="

repo=$(_tmpdir)
bin_dir=$(_tmpdir)
log=$(_tmpdir)/gh.log
export GH_LOG="$log"
_git_init "$repo"
_write_gh_stub "$bin_dir"

result=$(PATH="$bin_dir:$PATH" git -C "$repo" pr-checks 12 2>&1)
status=$?
_assert_status "passing checks exit zero" 0 "$status"
_assert_contains "summarizes passing checks" "checks: pass (2 pass)" "$result"
_assert_contains "prints check detail" "pass  build [ci] state=SUCCESS" "$result"

result=$(PATH="$bin_dir:$PATH" git -C "$repo" pr-checks 12 --porcelain 2>&1)
status=$?
_assert_status "porcelain passing checks exit zero" 0 "$status"
_assert_contains "porcelain includes aggregate state" "checks=pass" "$result"
_assert_contains "porcelain includes check record" $'check\tpass\tSUCCESS\tbuild\tci\thttps://example/check/build' "$result"

result=$(GH_CHECK_CASE=pending PATH="$bin_dir:$PATH" git -C "$repo" pr-checks 12 --porcelain 2>&1)
status=$?
_assert_status "pending checks use gh pending status" 8 "$status"
_assert_contains "porcelain includes pending state" "checks=pending" "$result"

result=$(GH_CHECK_CASE=fail PATH="$bin_dir:$PATH" git -C "$repo" pr-checks 12 2>&1)
status=$?
_assert_status "failing checks exit one" 1 "$status"
_assert_contains "summarizes failing checks" "checks: fail (1 pass, 1 fail)" "$result"

result=$(GH_CHECK_CASE=none PATH="$bin_dir:$PATH" git -C "$repo" pr-checks 12 --porcelain 2>&1)
status=$?
_assert_status "missing checks exit one" 1 "$status"
_assert_contains "porcelain reports no checks" "none=1" "$result"

: >"$log"
result=$(PATH="$bin_dir:$PATH" git -C "$repo" pr-checks 12 --required-only --watch --interval 3 2>&1)
status=$?
_assert_status "watching checks exits with final state" 0 "$status"
_assert_contains "watch passes required flag" "pr checks 12 --required --watch --interval 3" "$(<"$log")"
_assert_contains "summary read passes required flag" "pr checks 12 --required --json" "$(<"$log")"

result=$(PATH="$bin_dir:$PATH" git -C "$repo" pr-checks --interval 0 2>&1 || true)
_assert_contains "validates interval" "--interval must be greater than zero" "$result"

outside=$(_tmpdir)
result=$(PATH="$bin_dir:$PATH" git -C "$outside" pr-checks 2>&1 || true)
_assert_contains "requires git repo" "not inside a git repository" "$result"

if ((_failures > 0)); then
  printf '%s failure(s)\n' "$_failures" >&2
  exit 1
fi

printf 'all tests passed\n'
