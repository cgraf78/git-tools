#!/usr/bin/env bash

set -uo pipefail

ROOT=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)
PATH="$ROOT/bin:$PATH"
export NO_COLOR=1

_failures=0
_temps=()

_tmpdir() {
  local dir
  dir=$(mktemp -d)
  _temps+=("$dir")
  printf '%s\n' "$dir"
}

_cleanup() {
  local dir
  for dir in "${_temps[@]}"; do
    rm -rf "$dir"
  done
}
trap _cleanup EXIT

_pass() {
  printf 'ok - %s\n' "$1"
}

_fail() {
  printf 'not ok - %s\n' "$1" >&2
  _failures=$((_failures + 1))
}

_assert_eq() {
  local name="$1"
  local expected="$2"
  local actual="$3"

  if [[ "$actual" == "$expected" ]]; then
    _pass "$name"
  else
    _fail "$name"
    printf '  expected: %q\n' "$expected" >&2
    printf '  actual:   %q\n' "$actual" >&2
  fi
}

_assert_contains() {
  local name="$1"
  local needle="$2"
  local haystack="$3"

  if [[ "$haystack" == *"$needle"* ]]; then
    _pass "$name"
  else
    _fail "$name"
    printf '  expected output to contain: %s\n' "$needle" >&2
    printf '  actual output:\n%s\n' "$haystack" >&2
  fi
}

_git_init() {
  local repo="$1"
  git init -q --initial-branch=main "$repo"
  git -C "$repo" config user.email "test@test.com"
  git -C "$repo" config user.name "Test"
  git -C "$repo" config core.hooksPath /dev/null
  printf 'base\n' >"$repo/README.md"
  git -C "$repo" add README.md
  git -C "$repo" commit -m base >/dev/null
}

_write_tool_stubs() {
  local dir="$1"

  cat >"$dir/git-pr-stack" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail
case "${STACK_CASE:-ready}" in
  ready)
    printf 'pr\t0\t1\tmain\tfeature/a\ttrue\tready\tpass\thttps://example/pr/1\n'
    printf 'pr\t1\t2\tfeature/a\tfeature/b\ttrue\tready\tpass\thttps://example/pr/2\n'
    printf 'pr\t2\t3\tfeature/b\tfeature/c\ttrue\tready\tpass\thttps://example/pr/3\n'
    ;;
  blocked)
    printf 'pr\t0\t1\tmain\tfeature/a\ttrue\tready\tpass\thttps://example/pr/1\n'
    printf 'pr\t1\t2\tfeature/a\tfeature/b\tfalse\tchecks pending\tpending\thttps://example/pr/2\n'
    ;;
esac
EOF

  cat >"$dir/git-pr-land" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail
printf 'land %s\n' "$*" >>"${STACK_LOG:?}"
EOF

  cat >"$dir/git-pr-restack" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail
printf 'restack %s\n' "$*" >>"${STACK_LOG:?}"
EOF

  cat >"$dir/gh" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail
_merge_state() {
  local target="$1"
  local count count_file

  case "${GH_MERGE_CASE:-clean}" in
    clean)
      printf 'CLEAN\n'
      ;;
    dirty)
      printf 'DIRTY\n'
      ;;
    dirty-then-clean)
      count_file="${GH_VIEW_COUNT:?}.$target"
      count=0
      [[ ! -f "$count_file" ]] || count=$(< "$count_file")
      count=$((count + 1))
      printf '%s\n' "$count" >"$count_file"
      if ((count == 1)); then
        printf 'DIRTY\n'
      else
        printf 'CLEAN\n'
      fi
      ;;
    *)
      printf 'unexpected merge case: %s\n' "$GH_MERGE_CASE" >&2
      exit 99
      ;;
  esac
}

if [[ "$1 $2" == "auth status" ]]; then
  exit 0
fi
if [[ "$1 $2" == "pr view" ]]; then
  merge_state=$(_merge_state "${3:-}")
  case "${3:-}" in
    2)
      printf '2\tOPEN\tfalse\t%s\tfeature/b\tmain\thttps://example/pr/2\tChild PR\n' "$merge_state"
      ;;
    3)
      printf '3\tOPEN\tfalse\t%s\tfeature/c\tmain\thttps://example/pr/3\tGrandchild PR\n' "$merge_state"
      ;;
    *)
      printf 'unexpected pr view target: %s\n' "${3:-}" >&2
      exit 99
      ;;
  esac
  exit 0
fi
if [[ "$1 $2" == "pr checks" ]]; then
  printf 'checks %s\n' "$*" >>"${STACK_LOG:?}"
  case "${GH_CHECK_CASE:-pass}" in
    pass)
      printf 'pass\n'
      ;;
    fail)
      printf 'fail\n'
      ;;
    none)
      printf 'none\n'
      ;;
  esac
  exit 0
fi
printf 'unexpected gh call: %s\n' "$*" >&2
exit 99
EOF

  chmod +x "$dir/git-pr-stack" "$dir/git-pr-land" "$dir/git-pr-restack" "$dir/gh"
}

echo "=== git pr-land-stack ==="

repo=$(_tmpdir)
bin_dir=$(_tmpdir)
log=$(_tmpdir)/stack.log
_git_init "$repo"
git -C "$repo" branch feature/a
git -C "$repo" branch feature/b
git -C "$repo" branch feature/c
_write_tool_stubs "$bin_dir"

PATH="$bin_dir:$PATH" GIT_TOOLS_TOOL_DIR="$bin_dir" STACK_LOG="$log" git -C "$repo" pr-land-stack 1 >/tmp/pr-land-stack.out 2>&1
expected="$(
  cat <<'EOF'
land 1 --method squash --keep-branch
restack 2 --base main --fork feature/a
checks pr checks 2 --json bucket --jq [.[].bucket] as $buckets | if ($buckets | length) == 0 then "none" elif any($buckets[]; . == "fail" or . == "cancel") then "fail" elif any($buckets[]; . == "pending") then "pending" else "pass" end
land 2 --method squash --keep-branch
restack 3 --base main --fork feature/b
checks pr checks 3 --json bucket --jq [.[].bucket] as $buckets | if ($buckets | length) == 0 then "none" elif any($buckets[]; . == "fail" or . == "cancel") then "fail" elif any($buckets[]; . == "pending") then "pending" else "pass" end
land 3 --method squash
EOF
)"
_assert_eq "lands and restacks in stack order" "$expected" "$(cat "$log")"
if git -C "$repo" show-ref --verify --quiet refs/heads/feature/a; then
  _fail "deletes first intermediate branch after child restack"
else
  _pass "deletes first intermediate branch after child restack"
fi
if git -C "$repo" show-ref --verify --quiet refs/heads/feature/b; then
  _fail "deletes second intermediate branch after child restack"
else
  _pass "deletes second intermediate branch after child restack"
fi
if git -C "$repo" show-ref --verify --quiet refs/heads/feature/c; then
  _pass "leaves final branch cleanup to git pr-land"
else
  _fail "leaves final branch cleanup to git pr-land"
fi
_assert_contains "reports stack completion" "landed stack rooted at PR #1" "$(</tmp/pr-land-stack.out)"

log_dirty=$(_tmpdir)/stack.log
view_count=$(_tmpdir)/view-count
PATH="$bin_dir:$PATH" GIT_TOOLS_TOOL_DIR="$bin_dir" GH_MERGE_CASE=dirty-then-clean GH_VIEW_COUNT="$view_count" STACK_LOG="$log_dirty" git -C "$repo" pr-land-stack 1 --check-timeout 3 --check-interval 1 >/tmp/pr-land-stack-dirty.out 2>&1
_assert_contains "waits through transient dirty merge state" "waiting for PR #2 after restack: merge DIRTY, checks pass" "$(</tmp/pr-land-stack-dirty.out)"
_assert_contains "lands after transient dirty merge state" "land 3 --method squash" "$(cat "$log_dirty")"

result=$(PATH="$bin_dir:$PATH" GIT_TOOLS_TOOL_DIR="$bin_dir" GH_MERGE_CASE=dirty STACK_LOG="$log" git -C "$repo" pr-land-stack 1 --check-timeout 1 --check-interval 1 2>&1 || true)
_assert_contains "times out persistent dirty merge state" "timed out waiting for PR #2 after restack: merge DIRTY, checks pass" "$result"

log_keep=$(_tmpdir)/stack.log
PATH="$bin_dir:$PATH" GIT_TOOLS_TOOL_DIR="$bin_dir" STACK_LOG="$log_keep" git -C "$repo" pr-land-stack 1 --method merge --keep-branch >/tmp/pr-land-stack-keep.out 2>&1
_assert_contains "passes keep-branch to land" "land 1 --method merge --keep-branch" "$(cat "$log_keep")"

log_dry=$(_tmpdir)/stack.log
PATH="$bin_dir:$PATH" GIT_TOOLS_TOOL_DIR="$bin_dir" STACK_LOG="$log_dry" git -C "$repo" pr-land-stack 1 --dry-run >/tmp/pr-land-stack-dry.out 2>&1
_assert_contains "dry run passes through to land" "land 1 --method squash --keep-branch --dry-run" "$(cat "$log_dry")"
_assert_contains "dry run passes through to restack" "restack 2 --base main --fork feature/a --dry-run" "$(cat "$log_dry")"

result=$(PATH="$bin_dir:$PATH" GIT_TOOLS_TOOL_DIR="$bin_dir" STACK_CASE=blocked STACK_LOG="$log" git -C "$repo" pr-land-stack 1 2>&1 || true)
_assert_contains "refuses unready stacks before landing" "PR #2 is not ready: checks pending" "$result"

result=$(PATH="$bin_dir:$PATH" GIT_TOOLS_TOOL_DIR="$bin_dir" GH_CHECK_CASE=fail STACK_LOG="$log" git -C "$repo" pr-land-stack 1 2>&1 || true)
_assert_contains "refuses failed post-restack checks" "PR #2 checks failed after restack" "$result"

result=$(PATH="$bin_dir:$PATH" GIT_TOOLS_TOOL_DIR="$bin_dir" STACK_LOG="$log" git -C "$repo" pr-land-stack 1 --method bad 2>&1 || true)
_assert_contains "validates merge method" "merge method must be squash, merge, or rebase" "$result"

result=$(PATH="$bin_dir:$PATH" GIT_TOOLS_TOOL_DIR="$bin_dir" STACK_LOG="$log" git -C "$repo" pr-land-stack 1 --check-timeout 0 2>&1 || true)
_assert_contains "validates check timeout" "--check-timeout must be greater than zero" "$result"

outside=$(_tmpdir)
result=$(PATH="$bin_dir:$PATH" GIT_TOOLS_TOOL_DIR="$bin_dir" STACK_LOG="$log" git -C "$outside" pr-land-stack 1 2>&1 || true)
_assert_contains "requires git repo" "not inside a git repository" "$result"

if ((_failures > 0)); then
  printf '%s failure(s)\n' "$_failures" >&2
  exit 1
fi

printf 'all tests passed\n'
