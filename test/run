#!/usr/bin/env bash

set -euo pipefail

ROOT=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)

# shellcheck source=lib/git-tools-inventory.sh
. "$ROOT/lib/git-tools-inventory.sh"

commands=()
while IFS= read -r command; do
  commands+=("$command")
done < <(git_tools_commands "$ROOT")
test_files=()
for command in "${commands[@]}"; do
  test_files+=("$ROOT/test/$command-test")
done

if command -v shellcheck >/dev/null 2>&1; then
  shellcheck -x -P "$ROOT" \
    "${commands[@]/#/$ROOT/bin/}" \
    "$ROOT"/completions/*.bash \
    "$ROOT/lib/git-tools-base.sh" \
    "$ROOT/lib/git-tools-inventory.sh" \
    "$ROOT/lib/git-tools-pr.sh" \
    "$ROOT/install.sh" \
    "$ROOT/test/extras-test" \
    "${test_files[@]}" \
    "$ROOT/test/run"
fi

"$ROOT/test/extras-test"
for command in "${commands[@]}"; do
  "$ROOT/test/$command-test"
done
