#!/usr/bin/env bash

set -euo pipefail

ROOT=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)

if command -v shellcheck >/dev/null 2>&1; then
  shellcheck "$ROOT/bin/git-absorb-and-rebase" \
    "$ROOT/bin/git-cleanup-repo" \
    "$ROOT/bin/git-pr-checks" \
    "$ROOT/bin/git-pr-land" \
    "$ROOT/bin/git-pr-land-stack" \
    "$ROOT/bin/git-pr-ready" \
    "$ROOT/bin/git-pr-restack" \
    "$ROOT/bin/git-pr-stack" \
    "$ROOT"/completions/*.bash \
    "$ROOT/lib/git-tools-pr.sh" \
    "$ROOT/install.sh" \
    "$ROOT/test/extras-test" \
    "$ROOT/test/git-absorb-and-rebase-test" \
    "$ROOT/test/git-cleanup-repo-test" \
    "$ROOT/test/git-pr-checks-test" \
    "$ROOT/test/git-pr-land-test" \
    "$ROOT/test/git-pr-land-stack-test" \
    "$ROOT/test/git-pr-ready-test" \
    "$ROOT/test/git-pr-restack-test" \
    "$ROOT/test/git-pr-stack-test" \
    "$ROOT/test/run"
fi

"$ROOT/test/extras-test"
"$ROOT/test/git-absorb-and-rebase-test"
"$ROOT/test/git-cleanup-repo-test"
"$ROOT/test/git-pr-checks-test"
"$ROOT/test/git-pr-land-test"
"$ROOT/test/git-pr-land-stack-test"
"$ROOT/test/git-pr-ready-test"
"$ROOT/test/git-pr-restack-test"
"$ROOT/test/git-pr-stack-test"
